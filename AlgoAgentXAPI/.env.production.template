# AlgoAgentX API - Production Environment Template
# Copy this file to .env.production and fill in the actual values

# ========================================
# CRITICAL PRODUCTION VARIABLES
# These are required for production startup
# ========================================

# Database Configuration (REQUIRED)
# Format: postgresql+asyncpg://username:password@host:port/database_name
DATABASE_URL="postgresql+asyncpg://algo_user:your_secure_password@your-db-host:5432/algo_production"

# JWT Configuration (REQUIRED)
# Generate a secure random string for production
JWT_SECRET_KEY="your-very-secure-jwt-secret-key-here-minimum-32-characters"
JWT_REFRESH_TOKEN_KEY="your-very-secure-refresh-token-key-here-minimum-32-characters"
JWT_ALGORITHM="HS256"

# Razorpay Payment Configuration (REQUIRED)
# Get these from your Razorpay dashboard
RAZORPAY_KEY_ID="your_razorpay_key_id_here"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret_here"
RAZORPAY_WEBHOOK_SECRET="your_razorpay_webhook_secret_here"

# ========================================
# ENVIRONMENT & CORS
# ========================================

# Environment (REQUIRED)
# Must be: development, staging, or production
ENV="production"

# Web Origin for CORS (REQUIRED in production)
# This should be your frontend domain
WEB_ORIGIN="https://your-frontend-domain.com"

# ========================================
# REDIS CONFIGURATION
# ========================================

# Redis Configuration (REQUIRED for Celery background tasks)
# Format: redis://username:password@host:port/db_number
# For production, use a managed Redis service
REDIS_URL="redis://your-redis-host:6379/0"
# Alternative: individual Redis settings
REDIS_HOST="your-redis-host"
REDIS_PORT=6379
REDIS_DB=0

# ========================================
# SECURITY HEADERS
# ========================================

# HSTS Configuration (Optional - defaults provided)
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=true

# ========================================
# OPTIONAL CONFIGURATION
# ========================================

# SMTP Configuration (Optional - for future email features)
SMTP_EMAIL="noreply@your-domain.com"
SMTP_PASSWORD="your-smtp-password"

# Base URL (Optional)
BASE_URL="https://api.your-domain.com"

# Auth Service URL (Optional - for centralized auth)
AUTH_SERVICE_URL="https://auth.your-domain.com"

# ========================================
# DEVELOPMENT/STAGING VARIABLES
# ========================================

# For staging environment, you might use:
# ENV="staging"
# WEB_ORIGIN="https://staging.your-frontend.com"
# DATABASE_URL="postgresql+asyncpg://algo_user:staging_password@staging-db:5432/algo_staging"
# REDIS_URL="redis://staging-redis:6379/0"

# ========================================
# SECURITY NOTES
# ========================================
#
# 1. NEVER commit .env.production to version control
# 2. Use strong, unique passwords and secrets
# 3. Rotate secrets regularly
# 4. Use environment-specific values for each deployment
# 5. Restrict database and Redis access to your application servers only
# 6. Use SSL/TLS for all connections
# 7. Consider using a secrets management service (AWS Secrets Manager, HashiCorp Vault, etc.)
#
# ========================================